{
  "name": "@beat-twin/agent-contract",
  "version": "0.0.0",
  "private": true,
  "description": "Versioned SongPatch validation, deterministic command compilation, and mutation-free previews.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@beat-twin/commands": "workspace:*",
    "@beat-twin/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
